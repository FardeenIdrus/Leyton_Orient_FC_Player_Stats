# Secrets / local config
.env

# Landed raw data (large, reproducible from source)
data/raw/*
!data/raw/.gitkeep

# Aggregated tables (derived from raw, reproducible by re-running aggregation)
data/processed/

# Downloaded Transfermarkt data (external, large, re-downloadable)
data/reference/transfermarkt/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
data/coverage_html/

# OS / editor
.DS_Store
