# Copy to .env and adjust. .env is gitignored, never commit real credentials.

# --- Postgres (consumed by the db service) ---
POSTGRES_USER=lofc
POSTGRES_PASSWORD=lofc
POSTGRES_DB=lofc

# --- Database URL (consumed by the app: SQLAlchemy / Alembic) ---
# Host is "db" inside docker-compose; use localhost when running on the host.
DATABASE_URL=postgresql+psycopg2://lofc:lofc@db:5432/lofc

# --- StatsBomb data source ---
# Default is free open data (no credentials needed).
# To use the paid API: set USE_OPEN_DATA=false and fill in the credentials.
USE_OPEN_DATA=true
SB_USERNAME=
SB_PASSWORD=

# --- Target competitions ---
# Unset = the open-data demo trio (PL / La Liga / Serie A 2015/16).
# Override as comma-separated competition_id:season_id:label entries, e.g. the
# EFL targets on the paid feed:
# SB_COMPETITIONS=4:318:League One 2025/26,4:317:League One 2024/25,5:318:League Two 2025/26,5:317:League Two 2024/25,65:318:National League 2025/26,65:317:National League 2024/25,3:318:Championship 2025/26,3:317:Championship 2024/25
# Containers read .env at start: run `docker compose up -d` after changing it.
SB_COMPETITIONS=
